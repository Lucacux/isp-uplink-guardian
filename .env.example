# ── ONU / EPON ────────────────────────────────────────────────────────
ONU_URL=http://192.168.77.1
ONU_HOST=192.168.77.1
ONU_USER=user
# La password del ONU NUNCA va al repo. En Dokploy cargala en Environment.
ONU_PASS=

# ── Chequeo de WAN (TCP-connect, liviano) ─────────────────────────────
WAN_TARGETS=8.8.8.8:53,1.1.1.1:443,9.9.9.9:53
CHECK_INTERVAL_SECS=30
CHECK_TIMEOUT_SECS=4
FAIL_THRESHOLD=4        # fallos seguidos para confirmar caída (~2 min)
OK_THRESHOLD=2          # éxitos seguidos para confirmar recuperación

# ── Política de reboot ────────────────────────────────────────────────
REBOOT_COOLDOWN_SECS=1200    # 20 min entre reboots
MAX_REBOOTS_WINDOW=3         # tope por ventana
REBOOT_WINDOW_SECS=21600     # ventana = 6 h
POST_REBOOT_GRACE_SECS=300   # espera de recuperación tras reiniciar
REQUIRE_ONU_UP=1             # solo reinicia si el ONU responde (cuelgue, no apagón)
DRY_RUN=0                    # 1 = localiza el botón Reboot pero NO reinicia

# ── Dashboard LAN ─────────────────────────────────────────────────────
DASHBOARD_PORT=8090

# ── Notificaciones ────────────────────────────────────────────────────
# Discord: flush diferido (se envía cuando vuelve internet).
DISCORD_WEBHOOK_URL=
# ntfy opcional (push local instantáneo; sirve en el corte si está en la LAN).
NTFY_URL=
NTFY_TOPIC=

# Zona horaria del contenedor.
TZ=America/Argentina/Buenos_Aires
